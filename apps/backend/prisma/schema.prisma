generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CANDIDATE
  RECRUITER
  COLLEGE
  ADMIN
}

model User {
  id                  String   @id @default(uuid())
  email               String   @unique
  passwordHash        String?
  name                String?
  role                Role     @default(CANDIDATE)
  isOwner             Boolean  @default(false)
  forcePasswordChange Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  resumes      Resume[]
  applications Application[]
  interviews   MockInterview[]
}

model Resume {
  id          String   @id @default(uuid())
  title       String   @default("Untitled Resume")
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Comprehensive Personal Info
  fullName           String?
  preferredName      String?
  professionalTitle  String?
  phone              String?
  country            String?
  state              String?
  city               String?
  
  // Social & Portfolio Links
  linkedin           String?
  github             String?
  portfolioUrl       String?
  personalWebsite    String?
  stackoverflow      String?
  leetcode           String?
  twitter            String?
  
  // Summaries
  executiveSummary   String? @db.Text
  objective          String? @db.Text
  elevatorPitch      String? @db.Text

  // Relational Data
  experiences     Experience[]
  educations      Education[]
  skills          Skill[]
  projects        Project[]
  certifications  Certification[]
  achievements    Achievement[]
  careerTargets   CareerTarget?
  
  atsReports      AtsReport[]
}

model CareerTarget {
  id                String   @id @default(uuid())
  resumeId          String   @unique
  resume            Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  targetRole        String?
  preferredIndustry String?
  dreamCompany      String?
  expectedSalary    String?
  yearsOfExperience String?
  employmentType    String?  // Full Time, Contract, etc.
  remotePreference  Boolean  @default(false)
  relocation        Boolean  @default(false)
}

model Experience {
  id               String   @id @default(uuid())
  resumeId         String
  resume           Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  
  companyName      String
  industry         String?
  location         String?
  role             String
  department       String?
  
  startDate        DateTime
  endDate          DateTime?
  isCurrent        Boolean  @default(false)
  employmentType   String?
  teamSize         Int?
  reportingManager String?
  
  technologiesUsed String[]
  responsibilities String? @db.Text
  achievements     String? @db.Text
  metrics          String? @db.Text
  revenueImpact    String?
  costSavings      String?
  leadershipExp    Boolean @default(false)
}

model Project {
  id               String   @id @default(uuid())
  resumeId         String
  resume           Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  
  projectName      String
  projectType      String?
  domain           String?
  problemStatement String? @db.Text
  objective        String? @db.Text
  
  technologies     String[]
  cloudServices    String[]
  databases        String[]
  
  teamSize         Int?
  duration         String?
  role             String?
  
  results          String? @db.Text
  performance      String?
  githubLink       String?
  liveDemoLink     String?
}

model Education {
  id             String   @id @default(uuid())
  resumeId       String
  resume         Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  institution    String
  degree         String
  specialization String?
  gpa            String?
  percentage     String?
  startDate      DateTime
  endDate        DateTime?
  coursework     String[]
  thesis         String?
}

model Certification {
  id           String   @id @default(uuid())
  resumeId     String
  resume       Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  name         String
  organization String
  credentialId String?
  expiryDate   DateTime?
  url          String?
}

model Achievement {
  id           String   @id @default(uuid())
  resumeId     String
  resume       Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  title        String
  category     String   // Award, Publication, Hackathon, etc.
  date         DateTime?
  description  String? @db.Text
}

model Skill {
  id       String  @id @default(uuid())
  resumeId String
  resume   Resume  @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  name     String
  category String? // Programming, Framework, Soft Skill, etc.
  level    String? // Beginner, Intermediate, Expert
}

model AtsReport {
  id          String   @id @default(uuid())
  resumeId    String
  resume      Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  jobId       String?
  job         Job?     @relation(fields: [jobId], references: [id])
  
  // ATS 2.0 Comprehensive Scores
  overallScore          Int
  atsCompatibilityScore Int
  recruiterScore        Int
  keywordScore          Int
  industryScore         Int
  readabilityScore      Int
  
  missingKeywords String[]
  matchedKeywords String[]
  formattingIssues String[]
  
  createdAt   DateTime @default(now())
}

model Job {
  id          String   @id @default(uuid())
  title       String
  company     String
  description String   @db.Text
  createdAt   DateTime @default(now())
  atsReports  AtsReport[]
}

model Application {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company     String
  role        String
  status      String   @default("applied") // applied, screening, interview, offer, rejected
  appliedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MockInterview {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score       Int?
  feedback    String?  @db.Text
  createdAt   DateTime @default(now())
}
